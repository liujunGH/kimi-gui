{
  "name": "kimi-gui",
  "private": true,
  "version": "1.0.1",
  "description": "Kimi Code native desktop client (Tauri + Vue 3)",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build && bash scripts/make-dmg.sh",
    "web:dev": "pnpm --filter @moonshot-ai/kimi-web dev",
    "web:build": "pnpm --filter @moonshot-ai/kimi-web build",
    "web:typecheck": "pnpm --filter @moonshot-ai/kimi-web typecheck",
    "postbuild": "node -e \"require('fs').copyFileSync('web/dist/app.html','web/dist/index.html')\"",
    "build:dmg": "bash scripts/make-dmg.sh"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2"
  }
}
