{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Kimi Code",
  "version": "0.2.0",
  "identifier": "com.moonshot.kimigui",
  "build": {
    "beforeDevCommand": "pnpm --filter @moonshot-ai/kimi-web dev",
    "devUrl": "http://localhost:5175/app.html",
    "beforeBuildCommand": "pnpm --filter @moonshot-ai/kimi-web build && pnpm postbuild",
    "frontendDist": "../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "title": "Kimi Code",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "url": "app.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "app",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
